---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title={project.data.title} description={project.data.description}>
  <article class="section">
    <div class="section-inner article-inner">
      <a href={`${base}/#projects`} class="back-link">&larr; Projects</a>
      <div class="article-header">
        <span class="project-tag">{project.data.tag}</span>
        <h1 class="article-title">{project.data.title}</h1>
        <p class="article-desc">{project.data.description}</p>
        <ul class="article-techs">
          {project.data.techs.map((tech: string) => (
            <li>{tech}</li>
          ))}
        </ul>
        <div class="article-links">
          {project.data.url && (
            <a href={project.data.url} class="article-link" target="_blank" rel="noopener noreferrer">
              Live Demo &rarr;
            </a>
          )}
          {project.data.repo && (
            <a href={project.data.repo} class="article-link" target="_blank" rel="noopener noreferrer">
              Repository &rarr;
            </a>
          )}
        </div>
      </div>
      <div class="article-content">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .article-inner {
    max-inline-size: 48rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-block-end: 2rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .article-header {
    margin-block-end: 3rem;
    padding-block-end: 2rem;
    border-block-end: 1px solid var(--color-border);
  }

  .project-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--color-accent-subtle);
    color: var(--red-600);
    border-radius: var(--radius-full);
    margin-block-end: 1rem;
  }

  .article-title {
    font-size: clamp(2rem, 1.5rem + 3vw, 2.75rem);
    font-weight: 800;
    margin-block-end: 0.75rem;
  }

  .article-desc {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-block-end: 1.5rem;
  }

  .article-techs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-block-end: 1.5rem;
  }

  .article-techs li {
    font-size: 0.8rem;
    padding: 0.25rem 0.7rem;
    background: var(--gray-100);
    color: var(--gray-600);
    border-radius: var(--radius-full);
    font-weight: 500;
  }

  .article-links {
    display: flex;
    gap: 1rem;
  }

  .article-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: opacity 0.2s;
  }

  .article-link:hover {
    opacity: 0.8;
  }

  .article-content {
    font-size: 1.02rem;
    line-height: 1.8;
  }

  .article-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-block: 2.5rem 1rem;
  }

  .article-content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin-block: 2rem 0.75rem;
  }

  .article-content :global(p) {
    margin-block-end: 1rem;
    color: var(--gray-600);
  }

  .article-content :global(ul) {
    margin-block-end: 1.25rem;
    padding-inline-start: 1.5rem;
  }

  .article-content :global(li) {
    margin-block-end: 0.4rem;
    color: var(--gray-600);
  }

  .article-content :global(li strong) {
    color: var(--color-text);
  }

  .article-content :global(pre) {
    padding: 1.25rem;
    border-radius: var(--radius-md);
    background: var(--gray-900);
    color: var(--gray-100);
    overflow-x: auto;
    margin-block-end: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .article-content :global(code:not(pre code)) {
    padding: 0.15rem 0.4rem;
    background: var(--gray-100);
    border-radius: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.875em;
  }
</style>
