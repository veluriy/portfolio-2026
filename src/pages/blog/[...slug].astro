---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="section">
    <div class="section-inner article-inner">
      <a href={`${import.meta.env.BASE_URL}blog`} class="back-link">&larr; Blog</a>
      <div class="article-header">
        <div class="article-meta">
          <time datetime={post.data.date}>{post.data.date}</time>
          <ul class="article-tags">
            {post.data.tags.map((tag: string) => (
              <li>{tag}</li>
            ))}
          </ul>
        </div>
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-desc">{post.data.description}</p>
      </div>
      <div class="article-content">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .article-inner {
    max-inline-size: 48rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-block-end: 2rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .article-header {
    margin-block-end: 3rem;
    padding-block-end: 2rem;
    border-block-end: 1px solid var(--color-border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-block-end: 1rem;
  }

  .article-meta time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .article-tags {
    display: flex;
    gap: 0.4rem;
  }

  .article-tags li {
    font-size: 0.7rem;
    padding: 0.15rem 0.55rem;
    background: var(--color-accent-subtle);
    color: var(--red-600);
    border-radius: var(--radius-full);
    font-weight: 600;
  }

  .article-title {
    font-size: clamp(2rem, 1.5rem + 3vw, 2.75rem);
    font-weight: 800;
    margin-block-end: 0.75rem;
  }

  .article-desc {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .article-content {
    font-size: 1.02rem;
    line-height: 1.8;
  }

  .article-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-block: 2.5rem 1rem;
  }

  .article-content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin-block: 2rem 0.75rem;
  }

  .article-content :global(p) {
    margin-block-end: 1rem;
    color: var(--gray-600);
  }

  .article-content :global(ul) {
    margin-block-end: 1.25rem;
    padding-inline-start: 1.5rem;
  }

  .article-content :global(li) {
    margin-block-end: 0.4rem;
    color: var(--gray-600);
  }

  .article-content :global(li strong) {
    color: var(--color-text);
  }

  .article-content :global(pre) {
    padding: 1.25rem;
    border-radius: var(--radius-md);
    background: var(--gray-900);
    color: var(--gray-100);
    overflow-x: auto;
    margin-block-end: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .article-content :global(code:not(pre code)) {
    padding: 0.15rem 0.4rem;
    background: var(--gray-100);
    border-radius: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.875em;
  }
</style>
