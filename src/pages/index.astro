---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import {
  hero,
  about,
  affiliation,
  education,
  internships,
  skills,
  contacts,
} from "../data/profile";

const projects = await getCollection("projects");
---

<Layout title="Portfolio" description="My portfolio site">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-greeting">{hero.greeting}</p>
        <h1 class="hero-name">{hero.name}</h1>
        <p class="hero-tagline">{hero.tagline}</p>
        <div class="hero-actions">
          <a href="#projects" class="btn btn-primary">View Projects</a>
          <a href="#contact" class="btn btn-outline">Contact</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-avatar-ring">
          <img src={hero.avatar} alt="Avatar" width="280" height="280" />
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section">
    <div class="section-inner about-grid">
      <div>
        <span class="accent-line"></span>
        <h2 class="section-title">About</h2>
        {about.paragraphs.map((text) => (
          <p class="about-text">{text}</p>
        ))}
      </div>
      <div class="about-stats">
        {about.stats.map((stat) => (
          <div class="stat-card">
            <span class="stat-number">{stat.number}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Affiliation -->
  <section id="affiliation" class="section section-alt">
    <div class="section-inner">
      <span class="accent-line"></span>
      <h2 class="section-title">Affiliation</h2>
      <p class="section-subtitle">現在の所属</p>
      <div class="affiliation-card">
        <div class="affiliation-badge">現在</div>
        <h3 class="affiliation-org">{affiliation.org}</h3>
        <p class="affiliation-role">{affiliation.role}</p>
        <p class="affiliation-detail">{affiliation.detail}</p>
      </div>
    </div>
  </section>

  <!-- Education -->
  <section id="education" class="section">
    <div class="section-inner">
      <span class="accent-line"></span>
      <h2 class="section-title">Education</h2>
      <p class="section-subtitle">学歴</p>
      <div class="timeline">
        {education.map((item) => (
          <div class:list={["timeline-item", { "is-current": item.current }]}>
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-period">{item.period}</span>
              <h3 class="timeline-org">{item.org}</h3>
              <p class="timeline-detail">{item.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Internship -->
  <section id="internship" class="section section-alt">
    <div class="section-inner">
      <span class="accent-line"></span>
      <h2 class="section-title">Internship</h2>
      <p class="section-subtitle">インターン経験</p>
      <div class="timeline">
        {internships.map((item) => (
          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-period">{item.period}</span>
              <h3 class="timeline-org">{item.org}</h3>
              <p class="timeline-role">{item.role}</p>
              <p class="timeline-detail">{item.detail}</p>
              <ul class="timeline-techs">
                {item.techs.map((t) => <li>{t}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="section">
    <div class="section-inner">
      <span class="accent-line"></span>
      <h2 class="section-title">Skills</h2>
      <p class="section-subtitle">使用している技術スタック（とconfidence...）</p>
      <div class="skills-grid">
        {skills.map((skill) => (
          <div class="skill-card">
            <div class="skill-header">
              <span class="skill-name">{skill.name}</span>
              <span class="skill-percent">{skill.level}%</span>
            </div>
            <div class="skill-bar" role="progressbar" aria-valuenow={skill.level} aria-valuemin={0} aria-valuemax={100} aria-label={skill.name}>
              <div class="skill-fill" style={`--level: ${skill.level}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="section">
    <div class="section-inner">
      <span class="accent-line"></span>
      <h2 class="section-title">Projects</h2>
      <p class="section-subtitle">これまでの制作物</p>
      <div class="projects-grid">
        {projects.map((project) => (
          <a href={`/projects/${project.id}`} class="project-card">
            <div class="project-tag">{project.data.tag}</div>
            <h3 class="project-name">{project.data.title}</h3>
            <p class="project-desc">{project.data.description}</p>
            <ul class="project-techs">
              {project.data.techs.map((tech: string) => (
                <li>{tech}</li>
              ))}
            </ul>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section section-alt">
    <div class="section-inner contact-inner">
      <span class="accent-line"></span>
      <h2 class="section-title">Contact</h2>
      <p class="section-subtitle">お気軽にご連絡ください</p>
      <div class="contact-links">
        {contacts.map((c) => (
          <a
            href={c.href}
            class="contact-card"
            {...(c.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            <span class="contact-label">{c.label}</span>
            <span class="contact-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding-block: clamp(4rem, 10vw, 8rem) var(--section-spacing);
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    background:
      radial-gradient(ellipse 80% 60% at 70% 20%, oklch(0.55 0.22 22 / 0.07), transparent),
      radial-gradient(ellipse 50% 40% at 20% 80%, oklch(0.55 0.22 22 / 0.04), transparent);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 3rem;
    max-inline-size: var(--content-max);
    margin-inline: auto;
  }

  .hero-greeting {
    font-size: 1.1rem;
    color: var(--color-accent);
    font-weight: 600;
    margin-block-end: 0.5rem;
  }

  .hero-name {
    font-size: clamp(3rem, 2rem + 5vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--red-600), var(--red-400));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }

  .hero-tagline {
    font-size: clamp(1.15rem, 1rem + 1vw, 1.5rem);
    color: var(--color-text-muted);
    margin-block: 1rem 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.8rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.95rem;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    min-block-size: 44px;
  }

  .btn:hover:not(:disabled) {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
    box-shadow: 0 4px 14px oklch(0.55 0.22 22 / 0.3);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    box-shadow: 0 6px 20px oklch(0.55 0.22 22 / 0.35);
  }

  .btn-outline {
    border: 1.5px solid var(--color-border);
    background: var(--color-surface);
  }

  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hero-avatar-ring {
    position: relative;
    padding: 5px;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, var(--red-400), var(--red-600));
  }

  .hero-avatar-ring img {
    border-radius: var(--radius-full);
    display: block;
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-text {
    font-size: 1.05rem;
    color: var(--gray-600);
    line-height: 1.8;
    margin-block-end: 1rem;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 1.5rem 1rem;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .stat-number {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-accent);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  /* Affiliation */
  .affiliation-card {
    position: relative;
    padding: 2rem;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    border-inline-start: 4px solid var(--color-accent);
  }

  .affiliation-badge {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    font-size: 0.7rem;
    font-weight: 700;
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius-full);
    margin-block-end: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .affiliation-org {
    font-size: 1.35rem;
    font-weight: 700;
    margin-block-end: 0.4rem;
  }

  .affiliation-role {
    font-size: 0.95rem;
    color: var(--color-accent);
    font-weight: 600;
    margin-block-end: 0.75rem;
  }

  .affiliation-detail {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* Timeline (Education & Internship) */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-inline-start: 2rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    inset-inline-start: 0.45rem;
    inset-block-start: 0.6rem;
    inset-block-end: 0.6rem;
    inline-size: 2px;
    background: var(--color-border);
  }

  .timeline-item {
    position: relative;
    padding-block-end: 2.5rem;
  }

  .timeline-item:last-child {
    padding-block-end: 0;
  }

  .timeline-dot {
    position: absolute;
    inset-inline-start: -2rem;
    inset-block-start: 0.35rem;
    inline-size: 12px;
    block-size: 12px;
    border-radius: var(--radius-full);
    background: var(--color-border);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 2px var(--color-border);
  }

  .timeline-item.is-current .timeline-dot {
    background: var(--color-accent);
    box-shadow: 0 0 0 2px var(--color-accent);
  }

  .timeline-content {
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .timeline-period {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin-block-end: 0.4rem;
  }

  .timeline-org {
    font-size: 1.1rem;
    font-weight: 700;
    margin-block-end: 0.25rem;
  }

  .timeline-role {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--gray-500);
    margin-block-end: 0.4rem;
  }

  .timeline-detail {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .timeline-techs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-block-start: 0.75rem;
  }

  .timeline-techs li {
    font-size: 0.7rem;
    padding: 0.15rem 0.55rem;
    background: var(--color-accent-subtle);
    color: var(--red-600);
    border-radius: var(--radius-full);
    font-weight: 600;
  }

  /* Skills */
  .section-alt {
    background: var(--color-bg-subtle);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
    gap: 1.25rem;
  }

  .skill-card {
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .skill-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .skill-header {
    display: flex;
    justify-content: space-between;
    margin-block-end: 0.6rem;
  }

  .skill-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .skill-percent {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 700;
  }

  .skill-bar {
    block-size: 6px;
    background: var(--gray-100);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .skill-fill {
    block-size: 100%;
    inline-size: var(--level);
    background: linear-gradient(90deg, var(--red-400), var(--red-500));
    border-radius: var(--radius-full);
    animation: fill-in 1s ease-out;
  }

  @keyframes fill-in {
    from { inline-size: 0; }
  }

  /* Projects */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.25s, transform 0.25s, border-color 0.25s;
  }

  .project-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: var(--red-200);
  }

  .project-tag {
    display: inline-block;
    align-self: start;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--color-accent-subtle);
    color: var(--red-600);
    border-radius: var(--radius-full);
    margin-block-end: 1rem;
  }

  .project-name {
    font-size: 1.2rem;
    font-weight: 700;
    margin-block-end: 0.5rem;
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    flex-grow: 1;
    margin-block-end: 1rem;
  }

  .project-techs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-techs li {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    background: var(--gray-100);
    color: var(--gray-600);
    border-radius: var(--radius-full);
    font-weight: 500;
  }

  /* Contact */
  .contact-inner {
    text-align: center;
  }

  .contact-inner .accent-line {
    margin-inline: auto;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .contact-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.25rem 2rem;
    min-inline-size: 14rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    font-weight: 600;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .contact-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .contact-arrow {
    color: var(--color-accent);
    font-size: 1.2rem;
    transition: transform 0.2s;
  }

  .contact-card:hover .contact-arrow {
    transform: translateX(4px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-visual {
      order: -1;
    }

    .hero-avatar-ring img {
      inline-size: 180px;
      block-size: 180px;
    }

    .hero-actions {
      justify-content: center;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-fill {
      animation: none;
    }
  }
</style>
