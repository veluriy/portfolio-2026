---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portfolio" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" integrity="sha384-5TcZemv2l/9On385z///+d7MSYlvIEw9FuZTIdZ14vJLqWphw7e7ZPuOiCHJcFCP" crossorigin="anonymous">
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href={`${base}/`} class="logo">
          <img src="https://avatars.githubusercontent.com/u/64892129?v=4" alt="Avatar" width="36" height="36" />
          <span>Portfolio</span>
        </a>

        <!-- Desktop nav -->
        <ul class="nav-desktop">
          <li><a href={`${base}/#about`}>About</a></li>
          <li><a href={`${base}/#skills`}>Skills</a></li>
          <li><a href={`${base}/#projects`}>Projects</a></li>
          <li><a href={`${base}/blog`}>Blog</a></li>
          <li><a href={`${base}/#contact`}>Contact</a></li>
        </ul>

        <!-- Hamburger button (Invoker Commands API) -->
        <button class="hamburger" commandfor="nav-menu" command="toggle-popover" aria-label="Menu">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>

        <!-- Pulldown menu (Popover API) -->
        <div id="nav-menu" popover class="nav-pulldown">
          <ul>
            <li><a href={`${base}/#about`}>About</a></li>
            <li><a href={`${base}/#education`}>Education</a></li>
            <li><a href={`${base}/#internship`}>Internship</a></li>
            <li><a href={`${base}/#skills`}>Skills</a></li>
            <li><a href={`${base}/#projects`}>Projects</a></li>
            <li><a href={`${base}/blog`}>Blog</a></li>
            <li><a href={`${base}/#contact`}>Contact</a></li>
          </ul>
        </div>
      </nav>
    </header>

    <script>
      if (!('commandForElement' in HTMLButtonElement.prototype)) {
        import('https://esm.run/invokers-polyfill');
      }
    </script>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>&copy; 2026 Portfolio. All rights reserved.</p>
    </footer>
  </body>
</html>

<style is:global>
  @layer reset, base, theme, components, utilities;

  @layer reset {
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    img {
      display: block;
      max-inline-size: 100%;
      block-size: auto;
    }

    ul {
      list-style: none;
    }

    a {
      color: inherit;
      text-decoration: none;
    }
  }

  @layer base {
    :root {
      /* Tier 1: Literal tokens */
      --red-50: oklch(0.97 0.02 25);
      --red-100: oklch(0.93 0.04 25);
      --red-200: oklch(0.85 0.08 25);
      --red-300: oklch(0.75 0.14 20);
      --red-400: oklch(0.65 0.2 20);
      --red-500: oklch(0.55 0.22 22);
      --red-600: oklch(0.48 0.2 22);
      --red-700: oklch(0.4 0.16 22);
      --red-800: oklch(0.32 0.12 22);
      --red-900: oklch(0.22 0.06 22);

      --gray-50: oklch(0.98 0.005 25);
      --gray-100: oklch(0.94 0.005 25);
      --gray-200: oklch(0.88 0.008 25);
      --gray-300: oklch(0.78 0.008 25);
      --gray-400: oklch(0.62 0.008 25);
      --gray-500: oklch(0.5 0.008 25);
      --gray-600: oklch(0.4 0.008 25);
      --gray-700: oklch(0.3 0.01 25);
      --gray-800: oklch(0.22 0.01 25);
      --gray-900: oklch(0.15 0.01 25);
      --gray-950: oklch(0.1 0.01 25);

      --font-sans: "Inter", "Hiragino Sans", "Noto Sans JP", system-ui, sans-serif;
      --font-mono: "JetBrains Mono", ui-monospace, monospace;

      /* Tier 2: Semantic tokens */
      --color-accent: var(--red-500);
      --color-accent-hover: var(--red-400);
      --color-accent-subtle: var(--red-100);
      --color-text: var(--gray-900);
      --color-text-muted: var(--gray-500);
      --color-bg: oklch(0.99 0.002 25);
      --color-bg-subtle: var(--gray-50);
      --color-surface: white;
      --color-border: var(--gray-200);

      /* Tier 3: UI tokens */
      --radius-sm: 0.5rem;
      --radius-md: 0.75rem;
      --radius-lg: 1.25rem;
      --radius-full: 9999px;
      --shadow-sm: 0 1px 3px oklch(0 0 0 / 0.06);
      --shadow-md: 0 4px 12px oklch(0 0 0 / 0.08);
      --shadow-lg: 0 8px 30px oklch(0 0 0 / 0.1);
      --content-max: 72rem;
      --section-spacing: clamp(4rem, 8vw, 8rem);

      color-scheme: light;
    }

    html {
      font-family: var(--font-sans);
      color: var(--color-text);
      background: var(--color-bg);
      line-height: 1.6;
      text-wrap: pretty;
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 {
      line-height: 1.2;
      text-wrap: balance;
    }
  }

  @layer components {
    .section {
      padding-block: var(--section-spacing);
      padding-inline: clamp(1.5rem, 4vw, 3rem);
    }

    .section-inner {
      max-inline-size: var(--content-max);
      margin-inline: auto;
    }

    .section-title {
      font-size: clamp(1.75rem, 1rem + 3vw, 2.5rem);
      font-weight: 700;
      margin-block-end: 0.5rem;
    }

    .section-subtitle {
      color: var(--color-text-muted);
      font-size: 1.05rem;
      margin-block-end: 3rem;
    }

    .accent-line {
      display: block;
      inline-size: 3rem;
      block-size: 3px;
      background: var(--color-accent);
      border-radius: var(--radius-full);
      margin-block-end: 1.5rem;
    }
  }
</style>

<style>
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: 100;
    background: oklch(0.99 0.002 25 / 0.85);
    backdrop-filter: blur(12px);
    border-block-end: 1px solid var(--color-border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-inline-size: var(--content-max);
    margin-inline: auto;
    padding: 0.75rem clamp(1.5rem, 4vw, 3rem);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .logo img {
    border-radius: var(--radius-full);
  }

  /* Desktop nav */
  .nav-desktop {
    display: flex;
    gap: 2rem;
  }

  .nav-desktop a {
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-desktop a:hover,
  .nav-desktop a:focus-visible {
    color: var(--color-accent);
  }

  /* Hamburger button */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    min-block-size: 44px;
    min-inline-size: 44px;
  }

  .hamburger-line {
    display: block;
    inline-size: 22px;
    block-size: 2px;
    background: var(--color-text);
    border-radius: var(--radius-full);
    transition: transform 0.2s, opacity 0.2s;
  }

  /* Pulldown menu (Popover) */
  .nav-pulldown {
    display: none;
  }

  @media (max-width: 768px) {
    .nav-desktop {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .nav-pulldown {
      display: none;
      position: fixed;
      inset-block-start: 0;
      inset-inline: 0;
      margin: 0;
      padding: 5rem 2rem 2rem;
      border: none;
      background: oklch(0.99 0.002 25 / 0.97);
      backdrop-filter: blur(16px);
      box-shadow: var(--shadow-lg);
      border-block-end: 1px solid var(--color-border);
      z-index: 99;
    }

    .nav-pulldown:where(:popover-open, .\:popover-open) {
      display: block;
    }

    .nav-pulldown ul {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .nav-pulldown a {
      display: block;
      padding: 0.85rem 0;
      font-size: 1.05rem;
      font-weight: 600;
      border-block-end: 1px solid var(--color-border);
      transition: color 0.2s;
    }

    .nav-pulldown li:last-child a {
      border-block-end: none;
    }

    .nav-pulldown a:hover,
    .nav-pulldown a:focus-visible {
      color: var(--color-accent);
    }
  }

  .site-footer {
    padding: 2rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    border-block-start: 1px solid var(--color-border);
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>
